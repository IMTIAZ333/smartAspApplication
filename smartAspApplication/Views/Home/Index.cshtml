@{
    ViewData["Title"] = "Home Page";
}

<!-- Hero Section -->
<section class="jumbotron text-center" style="background: url('/images/construction-banner.jpg') no-repeat center center; background-size: cover; color: white; padding: 100px 0;">
    <div class="container">
        <h1 class="display-4 font-weight-bold">Welcome to Marbal Mountain</h1>
        <p class="lead">Building the foundation of tomorrow with quality craftsmanship and reliable service.</p>
        <a href="#services" class="btn btn-primary btn-lg mt-3">Our Services</a>
        <a href="#contact" class="btn btn-outline-light btn-lg mt-3">Get a Quote</a>
    </div>
</section>

<!-- About Section -->
<section id="about" class="py-5 bg-light">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h2>Who We Are</h2>
                <p>With years of industry experience, <strong>Marbal Mountain Construction</strong> is your trusted partner for commercial and residential building projects. We pride ourselves on delivering structurally sound, aesthetically pleasing, and durable results on time and within budget.</p>
            </div>
            <div class="col-lg-6">
                <img src="/images/about-construction.jpg" class="img-fluid rounded" alt="Marbal Mountain Construction Team">
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section id="services" class="py-5">
    <div class="container text-center">
        <h2 class="mb-5">Our Services</h2>
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h4 class="card-title">General Contracting</h4>
                        <p class="card-text">Overseeing your project from the ground up with a strict adherence to safety and quality standards.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h4 class="card-title">Commercial Construction</h4>
                        <p class="card-text">Tailored building solutions for retail spaces, offices, and large-scale commercial developments.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h4 class="card-title">Renovations & Remodeling</h4>
                        <p class="card-text">Breathing new life into existing structures with our expert remodeling and structural upgrade services.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Call to Action -->
<section id="contact" class="py-5 bg-dark text-white text-center">
    <div class="container">
        <h2>Ready to Build Your Vision?</h2>
        <p class="lead">Contact us today to discuss your upcoming project and receive a free, no-obligation estimate.</p>
        <a href="tel:+1234567890" class="btn btn-success btn-lg mt-3"><i class="fas fa-phone"></i> Call (123) 456-7890</a>
    </div>
</section>
